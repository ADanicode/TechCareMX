---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'TechCareMX | Soporte técnico para computadoras y consolas',
	description = 'Landing page de TechCareMX con servicios express, reparaciones físicas y atención local por WhatsApp.',
} = Astro.props;
---

<!doctype html>
<html lang="es-MX">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="theme-color" content="#020617" />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>
